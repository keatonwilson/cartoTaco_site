---
import '../styles/global.css';
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/bold';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="shortcut icon" href="/no_words.png" />
    <link rel="icon" type="image/png" href="/no_words.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>CartoTaco — The Tucson Taco Guide That Actually Knows Tucson</title>
    <meta name="description" content="No algorithms. No sponsored results. Just the spots worth knowing. A curated guide to Tucson's best small, local Mexican restaurants." />

    <!-- Open Graph -->
    <meta property="og:title" content="CartoTaco — The Tucson Taco Guide" />
    <meta property="og:description" content="No algorithms. No sponsored results. Just the spots worth knowing." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cartotaco.com" />
    <meta property="og:image" content="https://cartotaco.com/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="CartoTaco — The Tucson Taco Guide" />
    <meta name="twitter:description" content="No algorithms. No sponsored results. Just the spots worth knowing." />
    <meta name="twitter:image" content="https://cartotaco.com/og-image.png" />

    <script is:inline>
      (function() {
        const root = document.documentElement;
        root.classList.add('no-transition');
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          root.classList.add('dark');
        }
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            root.classList.remove('no-transition');
          });
        });
      })();
    </script>
  </head>

  <body class="bg-bg-primary text-text-primary font-body antialiased">

    <!-- ===== NAV ===== -->
    <nav id="nav" class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border-strong">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/no_words.png" alt="CartoTaco logo" class="h-10 w-10" />
          <a href="#" class="font-display text-2xl font-extrabold text-text-primary uppercase tracking-wider">
            Carto<span class="text-accent">Taco</span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="https://carto-taco.vercel.app" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex text-xs font-bold font-body uppercase tracking-widest text-accent hover:text-accent-hover border border-accent px-4 py-2 hover:bg-accent hover:text-white">
            Open the App
          </a>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            class="p-2 text-text-secondary hover:text-text-primary"
          >
            <i class="ph ph-sun hidden dark:block text-xl"></i>
            <i class="ph ph-moon block dark:hidden text-xl"></i>
          </button>
        </div>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="relative pt-32 pb-24 md:pt-44 md:pb-32 bg-bg-primary grain overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl">
          <p class="font-body text-xs uppercase tracking-[0.3em] text-accent mb-6">Tucson, AZ</p>
          <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold leading-[0.95] uppercase text-text-primary">
            The taco guide<br/>
            that actually<br/>
            knows <span class="text-accent italic">Tucson.</span>
          </h1>
          <p class="mt-8 text-base sm:text-lg text-text-secondary max-w-xl leading-relaxed">
            No algorithms. No sponsored results.<br class="hidden sm:block" />
            Just the spots worth knowing.
          </p>
          <div class="mt-12">
            <a
              href="https://carto-taco.vercel.app"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-3 px-8 py-4 bg-accent text-white font-display font-bold uppercase tracking-wider text-sm hover:bg-accent-hover border-2 border-accent hover:border-accent-hover"
            >
              Open CartoTaco
              <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
          </div>
        </div>
      </div>
      <!-- Decorative slashes -->
      <div class="absolute top-20 right-8 md:right-16 text-accent/10 font-display text-[12rem] md:text-[20rem] font-extrabold leading-none select-none pointer-events-none" aria-hidden="true">
        //
      </div>
    </section>

    <!-- ===== THE PROBLEM ===== -->
    <section class="py-20 md:py-28 bg-bg-secondary relative grain overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-8">The problem</p>
        <div class="space-y-6">
          <p class="text-base sm:text-lg text-text-primary leading-relaxed">
            You've been there. You search for tacos, you get a list of the same five places with 4.2 stars and 800 reviews. Half of them are chains. The other half are fine. None of them are what you were looking for.
          </p>
          <p class="text-base sm:text-lg text-text-primary leading-relaxed">
            The problem isn't that there's not enough information. It's that the wisdom of the masses isn't actually wise&nbsp;&mdash; it's just <span class="text-accent font-bold">loud.</span>
          </p>
        </div>
        <!-- Struck-through star rating -->
        <div class="mt-12 flex items-center gap-4 opacity-60 line-through decoration-accent decoration-[3px]">
          <div class="flex gap-1">
            {[1,2,3,4].map(() => (
              <svg class="w-8 h-8 text-text-tertiary" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <svg class="w-8 h-8 text-text-tertiary opacity-30" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <span class="text-xl text-text-tertiary">4.2 (847 reviews)</span>
        </div>
      </div>
    </section>

    <!-- ===== THE PHILOSOPHY ===== -->
    <section class="py-20 md:py-32 bg-bg-primary relative grain overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-8">The idea</p>
        <div class="space-y-6">
          <p class="text-base sm:text-lg text-text-primary leading-relaxed">
            CartoTaco is built on a different idea: that one person who really knows a place is worth more than a thousand people who kinda liked it.
          </p>
          <p class="text-base sm:text-lg text-text-primary leading-relaxed">
            Every restaurant in here was chosen deliberately. You won't find everything&nbsp;&mdash; you'll find the right things. Spots that have been operating the same way for decades. Family places that don't have a website. Trucks that move. The taco that someone's abuela has been making since before you were born.
          </p>
        </div>
        <!-- Pull quote — big, rotated, raw -->
        <div class="mt-20 md:mt-24 -mx-2 sm:mx-0">
          <p class="font-display text-4xl sm:text-5xl md:text-7xl font-extrabold text-accent uppercase leading-[0.95] -rotate-1">
            This is a small<br/>list, on&nbsp;purpose.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section class="py-20 md:py-28 bg-bg-secondary relative grain overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">The app</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-primary uppercase mb-16">
          How it works
        </h2>
        <div class="grid md:grid-cols-3 gap-8 md:gap-6">
          <!-- Screenshot 1 -->
          <div>
            <div class="bg-bg-primary border-2 border-border-strong aspect-[9/16] mb-5 overflow-hidden">
              <img src="/carto_scrn_1.png" alt="App screenshot 1" class="w-full h-full object-cover" />
            </div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-text-primary">Small data, powerful viz</p>
          </div>
          <!-- Screenshot 2 -->
          <div>
            <div class="bg-bg-primary border-2 border-border-strong aspect-[9/16] mb-5 overflow-hidden">
              <img src="/carto_scrn_2.png" alt="App screenshot 2" class="w-full h-full object-cover" />
            </div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-text-primary">Filters and search to find what you want</p>
          </div>
          <!-- Screenshot 3 -->
          <div>
            <div class="bg-bg-primary border-2 border-border-strong aspect-[9/16] mb-5 overflow-hidden">
              <img src="/carto_scrn_3.png" alt="App screenshot 3" class="w-full h-full object-cover" />
            </div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-text-primary">Build custom taco-trails to maximize deliciousness</p>
          </div>
        </div>

        <!-- Feature grid -->
        <div class="mt-20 pt-16 border-t border-border">
          <h3 class="font-display text-2xl sm:text-3xl font-extrabold text-text-primary uppercase mb-10">
            Plus a lot more
          </h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-trophy text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Taco Summit</h4>
              <p class="text-xs text-text-secondary leading-relaxed">Can't agree where to eat? Share an anonymous ranked-choice voting link. Democracy decides.</p>
            </div>

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-magic-wand text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Taste Profile</h4>
              <p class="text-xs text-text-secondary leading-relaxed">Your taco archetype, derived from your favorites. 13 types from Heat Seeker to The Purist.</p>
            </div>

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-scales text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Spot Comparison</h4>
              <p class="text-xs text-text-secondary leading-relaxed">Put up to 3 spots side-by-side on a shareable URL. Settle the debate with data.</p>
            </div>

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-heart text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Favorites</h4>
              <p class="text-xs text-text-secondary leading-relaxed">Save your spots. Filter the map to show only what you love.</p>
            </div>

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-shuffle text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Surprise Me</h4>
              <p class="text-xs text-text-secondary leading-relaxed">One tap. One random spot. Sometimes the map knows better than you do.</p>
            </div>

            <div class="bg-bg-primary border-2 border-border-strong p-5 hover:border-accent transition-colors">
              <i class="ph ph-newspaper text-accent text-3xl mb-3 block"></i>
              <h4 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-2">Rich Spot Cards</h4>
              <p class="text-xs text-text-secondary leading-relaxed">Hours, proteins, salsa count, heat gauge, radar chart, and the handmade tortilla badge.</p>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ===== COMING SOON ===== -->
    <section class="py-20 md:py-28 bg-bg-primary relative grain overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">What's next</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-primary uppercase mb-4">
          On the roadmap
        </h2>
        <p class="text-sm text-text-secondary mb-14 max-w-xl">No launch dates. Just the direction.</p>
        <div class="grid sm:grid-cols-3 gap-6">

          <div class="border-2 border-dashed border-border-strong p-6 hover:border-accent transition-colors">
            <i class="ph ph-smiley-sticker text-accent text-3xl mb-4 block"></i>
            <div class="flex items-center gap-3 mb-3">
              <h3 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide">Anti-Review</h3>
              <span class="text-[10px] font-body font-bold uppercase tracking-widest text-accent border border-accent px-2 py-0.5 shrink-0">Coming Soon</span>
            </div>
            <p class="text-xs text-text-secondary leading-relaxed">No stars. No essays. Four emoji dimensions — Heat Legit, Authentic, Value, Vibe. Tap your honest read on a spot and move on.</p>
          </div>

          <div class="border-2 border-dashed border-border-strong p-6 hover:border-accent transition-colors">
            <i class="ph ph-map-pin text-accent text-3xl mb-4 block"></i>
            <div class="flex items-center gap-3 mb-3">
              <h3 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide">Check-Ins</h3>
              <span class="text-[10px] font-body font-bold uppercase tracking-widest text-accent border border-accent px-2 py-0.5 shrink-0">Coming Soon</span>
            </div>
            <p class="text-xs text-text-secondary leading-relaxed">Geo-fenced check-ins with notes, aficionado badges, a public taco passport profile, and your recent visits visible right on spot cards.</p>
          </div>

          <div class="border-2 border-dashed border-border-strong p-6 hover:border-accent transition-colors">
            <i class="ph ph-users-three text-accent text-3xl mb-4 block"></i>
            <div class="flex items-center gap-3 mb-3">
              <h3 class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide">Meetups</h3>
              <span class="text-[10px] font-body font-bold uppercase tracking-widest text-accent border border-accent px-2 py-0.5 shrink-0">Coming Soon</span>
            </div>
            <p class="text-xs text-text-secondary leading-relaxed">Create and discover real taco meetup events pinned to the map. Find your people. Eat together.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== THE CURATION ===== -->
    <section class="py-20 md:py-28 bg-bg-tertiary relative grain overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">The list</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-primary uppercase mb-14">
          A taste of what's inside
        </h2>
        <div class="space-y-6">
          <!-- Featured Spot 1 -->
          <div class="bg-bg-primary border-2 border-border-strong p-6 sm:p-8 hover:border-accent transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-lg sm:text-xl font-extrabold text-accent uppercase">El Antojo Poblano</h3>
                <span class="text-xs uppercase tracking-widest text-text-tertiary font-body">Westside</span>
              </div>
              <span class="shrink-0 mt-1 text-accent">
                <i class="ph ph-map-pin text-xl"></i>
              </span>
            </div>
            <p class="mt-3 text-sm text-text-secondary leading-relaxed">
              A family-run kitchen bringing real southern Mexican flavors to the Westside. The mole sauce comes straight from Puebla — made by their mother and shipped to Tucson. Get the huaraches.
            </p>
          </div>
          <!-- Featured Spot 2 -->
          <div class="bg-bg-primary border-2 border-border-strong p-6 sm:p-8 hover:border-accent transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-lg sm:text-xl font-extrabold text-accent uppercase">El Chivo de Oro</h3>
                <span class="text-xs uppercase tracking-widest text-text-tertiary font-body">South Side</span>
              </div>
              <span class="shrink-0 mt-1 text-accent">
                <i class="ph ph-map-pin text-xl"></i>
              </span>
            </div>
            <p class="mt-3 text-sm text-text-secondary leading-relaxed">
              A south-side food truck institution since 2008. Maria Elena Domínguez's goat birria has earned a devoted following — quesabirria, Sonoran hot dogs, and homemade tortillas on W. Irvington.
            </p>
          </div>
          <!-- Featured Spot 3 -->
          <div class="bg-bg-primary border-2 border-border-strong p-6 sm:p-8 hover:border-accent transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-lg sm:text-xl font-extrabold text-accent uppercase">Tacos Apson</h3>
                <span class="text-xs uppercase tracking-widest text-text-tertiary font-body">South 12th Avenue</span>
              </div>
              <span class="shrink-0 mt-1 text-accent">
                <i class="ph ph-map-pin text-xl"></i>
              </span>
            </div>
            <p class="mt-3 text-sm text-text-secondary leading-relaxed">
              No frills, no menu on the wall, just carne asada and <em>costilla</em> tacos done exactly right. The kind of place you drive past three times before you find it. Worth every wrong turn.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section class="py-20 md:py-28 bg-bg-primary relative grain overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">The person</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-primary uppercase mb-10">
          Why I made this
        </h2>
        <div class="space-y-5 text-base text-text-secondary leading-relaxed">
          <p>
            I've lived in Tucson long enough to know that the best food here doesn't show up on the first page of a search engine. It's in the places that don't have a marketing budget, that have never asked anyone for a review, that have been serving the same recipes for generations.
          </p>
          <p>
            I built CartoTaco because I'm a data nerd and wanted a guide I could hand to a friend&nbsp;&mdash; one that skips the noise and goes straight to the places that matter. No stars, no rankings, no algorithm deciding what you should eat. Just a short list of spots I'd stake my reputation on.
          </p>
          <p>
            This is a one-person project, and that's the point. Curation means someone is making choices. I'd rather give you ten great recommendations than a thousand mediocre ones.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== ACCOUNT BENEFITS ===== -->
    <section class="py-20 md:py-28 bg-bg-secondary relative grain overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">Free accounts</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-primary uppercase mb-4">
          Some things are better<br/>with a login.
        </h2>
        <p class="text-base text-text-secondary mb-10 max-w-xl leading-relaxed">
          Still free. Still no credit card. But your tacos get personal.
        </p>
        <div class="space-y-5 mb-12">
          <div class="flex items-start gap-4">
            <span class="text-accent font-display font-extrabold text-lg mt-0.5 shrink-0">→</span>
            <div>
              <p class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-1">Favorites</p>
              <p class="text-sm text-text-secondary leading-relaxed">Save your go-to spots. They sync across devices and power your Taste Profile.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-accent font-display font-extrabold text-lg mt-0.5 shrink-0">→</span>
            <div>
              <p class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-1">Taste Profile</p>
              <p class="text-sm text-text-secondary leading-relaxed">Your AI-generated taco archetype, built from what you actually favorite. Unlocks automatically once you've saved a few spots.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-accent font-display font-extrabold text-lg mt-0.5 shrink-0">→</span>
            <div>
              <p class="font-display text-sm font-extrabold text-text-primary uppercase tracking-wide mb-1">More coming</p>
              <p class="text-sm text-text-secondary leading-relaxed">Check-ins, taco passport, and a public profile are on the way.</p>
            </div>
          </div>
        </div>
        <a
          href="https://carto-taco.vercel.app"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-accent text-white font-display font-bold uppercase tracking-wider text-sm hover:bg-accent-hover border-2 border-accent hover:border-accent-hover"
        >
          Create a Free Account
          <ph-arrow-right class="group-hover:translate-x-1 transition-transform" size="16" weight="bold"></ph-arrow-right>
        </a>
        <p class="mt-4 text-xs text-text-tertiary">Or just browse without one — the map works great either way.</p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer id="open" class="py-16 md:py-24 bg-bg-secondary border-t-2 border-border-strong relative grain overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <div class="text-center mb-14">
          <p class="font-body text-xs uppercase tracking-[0.3em] text-text-tertiary mb-4">Free. No account needed.</p>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold text-text-primary uppercase mb-6">
            Ready to eat well?
          </h2>
          <a
            href="https://carto-taco.vercel.app"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-10 py-5 bg-accent text-white font-display font-bold uppercase tracking-wider text-base hover:bg-accent-hover border-2 border-accent hover:border-accent-hover"
          >
            Open CartoTaco
            <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform text-lg"></i>
          </a>
        </div>
        <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="font-display text-lg font-extrabold text-text-primary uppercase tracking-wider">
            Carto<span class="text-accent">Taco</span>
          </p>
          <div class="flex items-center gap-6 text-xs text-text-tertiary font-body uppercase tracking-widest">
            <a href="mailto:hello@cartotaco.com" class="hover:text-text-primary">Contact</a>
            <span>&copy; {new Date().getFullYear()}</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- ===== MOBILE STICKY CTA ===== -->
    <div class="fixed bottom-0 left-0 right-0 p-3 bg-bg-primary/90 backdrop-blur-md border-t-2 border-border-strong sm:hidden z-40">
      <a
        href="https://carto-taco.vercel.app"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-full px-6 py-3.5 bg-accent text-white font-display font-bold uppercase tracking-wider text-sm hover:bg-accent-hover"
      >
        Open CartoTaco
      </a>
    </div>

    <!-- Dark mode toggle script -->
    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function() {
        const root = document.documentElement;
        const isDark = root.classList.contains('dark');
        if (isDark) {
          root.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          root.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });
    </script>
  </body>
</html>
